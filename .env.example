# ============================================================
# OIAS — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# --- Core ---
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# --- Database (PostgreSQL 16) ---
DATABASE_URL=postgresql://oias:oias_dev@localhost:5432/oias

# --- Cache / Queue (Redis) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
# Must be at least 16 characters
JWT_SECRET=changeme_replace_with_32+_char_secret

# --- AI (Anthropic) ---
# Optional — AI features degrade gracefully without this
ANTHROPIC_API_KEY=

# --- Email (Resend) ---
# Optional — notifications degrade gracefully without this
RESEND_API_KEY=
FROM_EMAIL=notifications@oias.dev

# --- File Storage (Cloudflare R2 / S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=oias-attachments

# --- Plugin: CRM Sync ---
# Required only if crm_sync plugin is enabled
HUBSPOT_CLIENT_SECRET=

# --- Plugin: WhatsApp Intake ---
# Required only if whatsapp_intake plugin is enabled
WHATSAPP_API_TOKEN=

# --- Azure AI Foundry (Reasoning Agents) ---
# Project endpoint from ai.azure.com → project Overview tab.
# Format: https://<resource>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_FOUNDRY_ENDPOINT=
# Project API key from ai.azure.com → Settings → Keys and Endpoint.
AZURE_AI_FOUNDRY_API_KEY=
# Agent ID (asst_xxx) or display name. Foundry client resolves by name if not asst_.
AZURE_AI_FOUNDRY_AGENT=
# Foundry Agent Service REST API version.
AZURE_AI_FOUNDRY_API_VERSION=2025-05-01
